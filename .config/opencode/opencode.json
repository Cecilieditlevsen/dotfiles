{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-opencode@latest"],
  "model": "openai/gpt-5.3-codex",
  "keybinds": {
    "command_list": "ctrl+k"
  },
  "permission": {
    "bash": {
      "git commit *": "ask",
      "git push *": "ask"
    }
  },
  "mcp": {
    "figma-desktop": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "tanstack": {
      "type": "local",
      "command": ["pnpm", "dlx", "@tanstack/cli", "mcp"],
      "enabled": true
    }
  }
}
